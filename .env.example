# ============================================
# PONTO DIGITAL - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# ===== DATABASE (PostgreSQL - Neon free tier) =====
# Crie um banco grátis em https://neon.tech
# Copie a connection string do dashboard
DATABASE_URL="postgresql://usuario:senha@host.neon.tech/nomedb?sslmode=require"

# ===== AUTENTICAÇÃO =====
JWT_SECRET="troque-por-uma-chave-secreta-aleatoria-de-32-caracteres"
JWT_EXPIRES_IN="7d"

# ===== SERVIDOR =====
PORT=3001
NODE_ENV=production

# ===== APP =====
APP_URL="https://seu-app.vercel.app"
NOTIFICATION_TIMEZONE="America/Sao_Paulo"
