# ============================================
# PONTO DIGITAL - Variaveis de Ambiente
# ============================================

# ===== DATABASE (MySQL - Hostinger) =====
# Use o host remoto do MySQL informado pela Hostinger.
# Nao use localhost em producao na Hostinger.
# Voce pode informar a conexao completa:
DATABASE_URL="mysql://usuario_mysql:senha_mysql@srv1234.hstgr.io:3306/ponto_digital"
# Ou, se preferir, informar os campos separados:
DB_HOST="srv1234.hstgr.io"
DB_PORT="3306"
DB_USER="usuario_mysql"
DB_PASSWORD="senha_mysql"
DB_NAME="ponto_digital"
# Opcional, caso o provedor exija SSL:
DB_SSL="false"
# Se usar certificado proprio/self-signed, permita explicitamente:
DB_SSL_REJECT_UNAUTHORIZED="true"

# ===== MIGRACAO (fonte temporaria Postgres/Supabase) =====
# Use apenas durante a migracao de dados.
SOURCE_DATABASE_URL="postgresql://usuario:senha@host:5432/postgres?sslmode=require"

# ===== AUTENTICACAO =====
JWT_SECRET="troque-por-uma-chave-secreta-aleatoria-de-32-caracteres"
JWT_EXPIRES_IN="7d"

# ===== SERVIDOR =====
PORT=3001
NODE_ENV=production

# ===== APP =====
APP_URL="https://ponto.lbrcore.com"
FRONTEND_URL="https://ponto.lbrcore.com"
ALLOWED_ORIGINS="https://ponto.lbrcore.com"
NOTIFICATION_TIMEZONE="America/Sao_Paulo"

# ===== MERCADO PAGO =====
MP_ACCESS_TOKEN="TEST-0000000000000000-000000-00000000000000000000000000000000-000000000"
MP_PUBLIC_KEY="TEST-00000000-0000-0000-0000-000000000000"
MP_WEBHOOK_SECRET=""

# ===== FRONTEND =====
VITE_API_BASE_URL="/api"
VITE_MP_PUBLIC_KEY="TEST-00000000-0000-0000-0000-000000000000"

# ===== SUPER ADMIN =====
SUPER_ADMIN_EMAIL="superadmin@pontodigital.com.br"
SUPER_ADMIN_PASSWORD="SuperAdmin@123"
