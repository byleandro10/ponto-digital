# ============================================
# PONTO DIGITAL - Variaveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# ===== DATABASE (PostgreSQL - Supabase/Neon) =====
# Para o deploy inicial na Hostinger, mantenha o banco no Supabase.
# DATABASE_URL: usada pelo app em runtime
# DIRECT_URL: usada pelo Prisma para operacoes que exigem conexao direta
DATABASE_URL="postgresql://usuario:senha@db.xxxxx.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://usuario:senha@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# ===== AUTENTICACAO =====
JWT_SECRET="troque-por-uma-chave-secreta-aleatoria-de-32-caracteres"
JWT_EXPIRES_IN="7d"

# ===== SERVIDOR =====
PORT=3001
NODE_ENV=production

# ===== APP =====
APP_URL="https://ponto.lbrcore.com"
FRONTEND_URL="https://ponto.lbrcore.com"
ALLOWED_ORIGINS="https://ponto.lbrcore.com,https://api.lbrcore.com"
NOTIFICATION_TIMEZONE="America/Sao_Paulo"

# ===== MERCADO PAGO =====
# Crie sua conta em https://www.mercadopago.com.br/developers
# Para testes: use credenciais de teste (prefixo TEST-)
# Para producao: use credenciais de producao (prefixo APP_USR-)
MP_ACCESS_TOKEN="TEST-0000000000000000-000000-00000000000000000000000000000000-000000000"
MP_PUBLIC_KEY="TEST-00000000-0000-0000-0000-000000000000"
# Webhook secret: obtido no painel do MP > Webhooks > Configuracao
MP_WEBHOOK_SECRET=""

# ===== FRONTEND (prefixo VITE_ para expor ao browser) =====
VITE_API_BASE_URL="https://api.lbrcore.com/api"
VITE_MP_PUBLIC_KEY="TEST-00000000-0000-0000-0000-000000000000"

# ===== SUPER ADMIN =====
SUPER_ADMIN_EMAIL="superadmin@pontodigital.com.br"
SUPER_ADMIN_PASSWORD="SuperAdmin@123"
