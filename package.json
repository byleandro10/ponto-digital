{
  "name": "ponto-digital",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de Ponto Digital para Pequenas Empresas - SaaS",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "echo Use 'npm run dev:backend' e 'npm run dev:frontend' em terminais separados",
    "dev:backend": "cd backend && node src/app.js",
    "dev:frontend": "cd frontend && npx vite --port 3000 --host",
    "install:frontend": "npm --prefix frontend install --include=dev",
    "build:frontend": "npm --prefix frontend run build",
    "sync:root-dist": "node -e \"const fs=require('fs'); const path=require('path'); const src=path.join(process.cwd(),'frontend','dist'); const dest=path.join(process.cwd(),'dist'); fs.rmSync(dest,{recursive:true,force:true}); fs.cpSync(src,dest,{recursive:true}); console.log('Copied frontend/dist to dist');\"",
    "prisma:generate": "npx prisma generate --schema=backend/prisma/schema.prisma",
    "db:prepare": "node backend/scripts/ensure-db-schema.js",
    "migrate:data:mysql": "node backend/scripts/migrate-postgres-to-mysql.js",
    "build": "npm run install:frontend && npm run prisma:generate && npm run build:frontend && npm run sync:root-dist",
    "start": "npm run db:prepare && node backend/src/app.js",
    "postinstall": "npx prisma generate --schema=backend/prisma/schema.prisma",
    "db:push": "npx prisma db push --schema=backend/prisma/schema.prisma",
    "db:test:mysql2": "node backend/scripts/test-mysql2-connection.js",
    "billing:reconcile": "node backend/scripts/reconcile-billing.js",
    "db:studio": "npx prisma studio --schema=backend/prisma/schema.prisma",
    "test": "cd backend && npm test"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^6.16.0",
    "@prisma/client": "^6.16.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.15.2",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "prisma": "^6.16.0",
    "stripe": "^22.0.0"
  }
}
