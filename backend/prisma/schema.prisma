generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id                 String   @id @default(uuid())
  name               String
  cnpj               String   @unique
  plan               String   @default("basic")
  address            String?
  logoUrl            String?
  requireSelfie      Boolean  @default(false)
  geofenceMode       String   @default("off")
  subscriptionStatus String   @default("TRIAL")
  trialEndsAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users               User[]
  employees           Employee[]
  notificationSetting NotificationSetting?
  geofences           Geofence[]
  subscriptions       Subscription[]
  payments            Payment[]
  usageLogs           UsageLog[]
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id])
}

model Employee {
  id                 String   @id @default(uuid())
  name               String
  cpf                String   @unique
  email              String   @unique
  password           String
  phone              String?
  position           String?
  department         String?
  workloadHours      Float    @default(8)
  companyId          String
  active             Boolean  @default(true)
  hourBankBalance    Int      @default(0)
  workScheduleType   String   @default("standard")
  geofenceExempt     Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company            Company             @relation(fields: [companyId], references: [id])
  timeEntries        TimeEntry[]
  notifications      Notification[]
  adjustmentLogs     TimeAdjustmentLog[]
  adjustmentRequests AdjustmentRequest[]
}

model TimeEntry {
  id                String    @id @default(uuid())
  employeeId        String
  type              String
  timestamp         DateTime  @default(now())
  latitude          Float?
  longitude         Float?
  address           String?
  deviceInfo        String?
  photo             String?
  notes             String?
  insideGeofence    Boolean?
  geofenceName      String?
  adjustedBy        String?
  adjustedAt        DateTime?
  adjustmentNote    String?
  originalTimestamp DateTime?
  integrityHash     String?
  createdAt         DateTime  @default(now())

  employee           Employee            @relation(fields: [employeeId], references: [id])
  adjustmentRequests AdjustmentRequest[]
}

model TimeAdjustmentLog {
  id         String   @id @default(uuid())
  employeeId String
  entryId    String?
  action     String
  oldValue   String?
  newValue   String?
  reason     String
  adjustedBy String
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

model AdjustmentRequest {
  id             String    @id @default(uuid())
  employeeId     String
  entryId        String?
  requestType    String
  currentValue   String?
  requestedValue String?
  reason         String
  status         String    @default("PENDING")
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNote     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  employee  Employee   @relation(fields: [employeeId], references: [id])
  timeEntry  TimeEntry? @relation(fields: [entryId], references: [id])
}

model Geofence {
  id        String  @id @default(uuid())
  companyId String
  name      String
  latitude  Float
  longitude Float
  radius    Int
  active    Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id])
}

model Notification {
  id         String   @id @default(uuid())
  employeeId String
  type       String
  message    String
  sentAt     DateTime @default(now())
  read       Boolean  @default(false)

  employee Employee @relation(fields: [employeeId], references: [id])
}

model NotificationSetting {
  id                   String  @id @default(uuid())
  companyId            String  @unique
  clockInReminder      Boolean @default(true)
  clockOutReminder     Boolean @default(true)
  missingPunchAlert    Boolean @default(true)
  weeklyReport         Boolean @default(true)
  punchConfirmation    Boolean @default(true)
  clockInReminderTime  String  @default("07:50")
  clockOutReminderTime String  @default("17:50")

  company Company @relation(fields: [companyId], references: [id])
}

model Subscription {
  id                 String    @id @default(uuid())
  companyId          String
  plan               String
  status             String    @default("TRIAL")
  trialStart         DateTime?
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  gracePeriodEnd     DateTime?
  mpPreapprovalId    String?   @unique
  mpCustomerId       String?
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  company  Company   @relation(fields: [companyId], references: [id])
  payments Payment[]

  @@index([companyId])
  @@index([mpPreapprovalId])
}

model Payment {
  id             String    @id @default(uuid())
  subscriptionId String
  companyId      String
  mpPaymentId    String?   @unique
  amount         Decimal
  status         String    @default("PENDING")
  paidAt         DateTime?
  failureReason  String?
  createdAt      DateTime  @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  company      Company      @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([subscriptionId])
  @@index([mpPaymentId])
}

model UsageLog {
  id              String   @id @default(uuid())
  companyId       String
  date            DateTime @db.Date
  activeEmployees Int      @default(0)
  totalPunches    Int      @default(0)
  adminLogins     Int      @default(0)
  employeeLogins  Int      @default(0)
  createdAt       DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, date])
  @@index([companyId])
}
