generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id        String   @id @default(uuid())
  name      String
  cnpj      String   @unique
  plan      String   @default("basic")
  address   String?
  logoUrl   String?
  requireSelfie Boolean @default(false)
  geofenceMode  String  @default("off") // off | warn | block
  subscriptionStatus String @default("TRIAL") // TRIAL | ACTIVE | PAST_DUE | CANCELLED | EXPIRED
  trialEndsAt        DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  employees           Employee[]
  notificationSetting NotificationSetting?
  geofences           Geofence[]
  subscriptions       Subscription[]
  payments            Payment[]
  usageLogs           UsageLog[]
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ADMIN") // ADMIN | SUPER_ADMIN | MANAGER
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id])
}

model Employee {
  id            String   @id @default(uuid())
  name          String
  cpf           String   @unique
  email         String   @unique
  password      String
  phone         String?
  position      String?
  department    String?
  workloadHours Float    @default(8)
  companyId     String
  active        Boolean  @default(true)
  hourBankBalance Int    @default(0) // saldo banco de horas em minutos (+ ou -)

  // Tipo de jornada:
  //   standard   → entrada / almoço-saída / almoço-volta / saída (padrão CLT)
  //   no_break   → entrada / saída (sem intervalo de almoço)
  //   shift      → escala — múltiplos registros livres; apenas CLOCK_IN e CLOCK_OUT
  workScheduleType String @default("standard") // standard | no_break | shift

  // Isenção de cerca virtual (trabalha externamente — pode bater mesmo com modo "block")
  geofenceExempt Boolean @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id])
  timeEntries   TimeEntry[]
  notifications Notification[]
  adjustmentLogs TimeAdjustmentLog[]
  adjustmentRequests AdjustmentRequest[]
}

model TimeEntry {
  id         String   @id @default(uuid())
  employeeId String
  type       String
  timestamp  DateTime @default(now())
  latitude   Float?
  longitude  Float?
  address    String?
  deviceInfo String?
  photo      String?
  notes      String?
  insideGeofence Boolean? // null = sem geofence, true = dentro, false = fora
  geofenceName   String?  // nome da cerca onde bateu
  adjustedBy     String?  // userId de quem ajustou (null = original)
  adjustedAt     DateTime?
  adjustmentNote String?
  originalTimestamp DateTime? // timestamp original antes do ajuste
  integrityHash  String?  // SHA-256 para garantir imutabilidade do registro
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  adjustmentRequests AdjustmentRequest[]
}

model TimeAdjustmentLog {
  id          String   @id @default(uuid())
  employeeId  String
  entryId     String?  // null se foi adição de registro
  action      String   // EDIT | ADD | DELETE
  oldValue    String?  // JSON do valor antigo
  newValue    String?  // JSON do valor novo
  reason      String   // justificativa obrigatória
  adjustedBy  String   // userId do admin
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

model AdjustmentRequest {
  id            String   @id @default(uuid())
  employeeId    String
  entryId       String?  // registro existente (null = solicitar adição)
  requestType   String   // EDIT | ADD | DELETE
  currentValue  String?  // JSON do valor atual
  requestedValue String? // JSON do valor desejado (ex: { timestamp: "...", type: "CLOCK_IN" })
  reason        String   // justificativa obrigatória do funcionário
  status        String   @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewedBy    String?  // userId do admin que revisou
  reviewedAt    DateTime?
  reviewNote    String?  // nota do admin ao aprovar/rejeitar
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee  Employee   @relation(fields: [employeeId], references: [id])
  timeEntry TimeEntry? @relation(fields: [entryId], references: [id])
}

model Geofence {
  id        String  @id @default(uuid())
  companyId String
  name      String  // ex: "Matriz", "Filial Centro", "Obra Rua X"
  latitude  Float
  longitude Float
  radius    Int     // raio em metros
  active    Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id])
}

model Notification {
  id         String   @id @default(uuid())
  employeeId String
  type       String
  message    String
  sentAt     DateTime @default(now())
  read       Boolean  @default(false)

  employee Employee @relation(fields: [employeeId], references: [id])
}

model NotificationSetting {
  id                   String  @id @default(uuid())
  companyId            String  @unique
  clockInReminder      Boolean @default(true)
  clockOutReminder     Boolean @default(true)
  missingPunchAlert    Boolean @default(true)
  weeklyReport         Boolean @default(true)
  punchConfirmation    Boolean @default(true)
  clockInReminderTime  String  @default("07:50")
  clockOutReminderTime String  @default("17:50")

  company Company @relation(fields: [companyId], references: [id])
}

model Subscription {
  id                 String    @id @default(uuid())
  companyId          String
  plan               String    // BASIC | PROFESSIONAL | ENTERPRISE
  status             String    @default("TRIAL") // TRIAL | ACTIVE | PAST_DUE | CANCELLED | PAUSED
  trialStart         DateTime?
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  gracePeriodEnd     DateTime? // Fim da carência após falha de pagamento
  mpPreapprovalId    String?   @unique // ID da assinatura no Mercado Pago
  mpCustomerId       String?
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  company  Company   @relation(fields: [companyId], references: [id])
  payments Payment[]

  @@index([companyId])
  @@index([mpPreapprovalId])
}

model Payment {
  id              String    @id @default(uuid())
  subscriptionId  String
  companyId       String
  mpPaymentId     String?   @unique // ID do pagamento no Mercado Pago
  amount          Decimal
  status          String    @default("PENDING") // PENDING | APPROVED | REJECTED | REFUNDED
  paidAt          DateTime?
  failureReason   String?   // Motivo da falha de pagamento
  createdAt       DateTime  @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  company      Company      @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([subscriptionId])
  @@index([mpPaymentId])
}

model UsageLog {
  id              String   @id @default(uuid())
  companyId       String
  date            DateTime @db.Date
  activeEmployees Int      @default(0)
  totalPunches    Int      @default(0)
  adminLogins     Int      @default(0)
  employeeLogins  Int      @default(0)
  createdAt       DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, date])
  @@index([companyId])
}
